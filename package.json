{
  "name": "azurecraft-blog",
  "version": "1.0.0",
  "private": true,
  "description": "AzureCraft static blog hosted on Azure App Service",
  "main": "server.js",
  "scripts": {
    "start": "node --preserve-symlinks-main server.js",
    "dev": "node --preserve-symlinks-main server.js",
    "generate:og": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-og-images.ps1",
    "check": "node --preserve-symlinks-main scripts/check-site.js",
    "test": "npm run check"
  },
  "engines": {
    "node": ">=18"
  }
}
